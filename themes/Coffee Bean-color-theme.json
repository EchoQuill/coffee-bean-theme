        "scrollbarSlider.hoverBackground": "#ADC178ee",
        "selection.background": "#ADC178",
        "settings.checkboxBackground": "#4e3a2e",
        "settings.checkboxForeground": "#E8C99A",
        "settings.dropdownBackground": "#4e3a2e",
        "settings.dropdownForeground": "#E8C99A",
        "settings.headerForeground": "#ADC178",
        "settings.modifiedItemIndicator": "#ADC178",
        "settings.numberInputBackground": "#4e3a2e",
        "settings.numberInputForeground": "#E8C99A",
        "settings.textInputBackground": "#4e3a2e",
        "settings.textInputForeground": "#E8C99A",
        "sideBar.background": "#4e3a2e",
        "sideBar.border": "#ADC17840",
        "sideBar.foreground": "#C9A96E",
        "sideBarSectionHeader.background": "#4e3a2e",
        "sideBarSectionHeader.border": "#5C3D2E60",
        "sideBarSectionHeader.foreground": "#C9A96E",
        "sideBarTitle.foreground": "#E8C99A",
        "statusBar.background": "#4e3a2ecf",
        "statusBar.border": "#5C3D2E60",
        "statusBar.debuggingBackground": "#E0956A",
        "statusBar.debuggingForeground": "#2a2018",
        "statusBar.foreground": "#E8C99A",
        "statusBar.noFolderBackground": "#5C3D2E",
        "statusBarItem.hoverBackground": "#ADC17825",
        "statusBarItem.remoteBackground": "#ADC178",
        "statusBarItem.remoteForeground": "#2a2018",
        "tab.activeBackground": "#3a322a",
        "tab.activeBorder": "#ADC178",
        "tab.activeForeground": "#E8C99A",
        "tab.activeModifiedBorder": "#D4A853",
        "tab.border": "#4e3a2e",
        "tab.inactiveBackground": "#3d2e23",
        "tab.inactiveForeground": "#a07858",
        "tab.unfocusedActiveBorder": "#ADC178",
        "tab.unfocusedActiveBackground": "#4e3a2e",
        "tab.unfocusedActiveForeground": "#E8C99A",
        "tab.unfocusedInactiveBackground": "#3d2e23",
        "tab.unfocusedInactiveForeground": "#9a7860",
        "terminal.foreground": "#ADC178",
        "terminal.ansiBlack": "#4e3a2e",
        "terminal.ansiBlue": "#C9A96E",
        "terminal.ansiBrightBlack": "#ADC178",
        "terminal.ansiBrightBlue": "#C9A96E",
        "terminal.ansiBrightCyan": "#ADC178",
        "terminal.ansiBrightGreen": "#E8C99A",
        "terminal.ansiBrightMagenta": "#E0956A",
        "terminal.ansiBrightRed": "#E0956A",
        "terminal.ansiBrightWhite": "#E8C99A",
        "terminal.ansiBrightYellow": "#D4A853",
        "terminal.ansiCyan": "#ADC178",
        "terminal.ansiGreen": "#ADC178",
        "terminal.ansiMagenta": "#E0956A",
        "terminal.ansiRed": "#E0956A",
        "terminal.ansiWhite": "#E8C99A",
        "terminal.ansiYellow": "#D4A853",
        "terminalCursor.background": "#4e3a2e",
        "terminalCursor.foreground": "#E8C99A",
        "textLink.activeForeground": "#E8C99A",
        "textLink.foreground": "#ADC178",
        "titleBar.activeBackground": "#4e3a2ecf",
        "titleBar.activeForeground": "#E8C99A",
        "titleBar.border": "#5C3D2E60",
        "titleBar.inactiveBackground": "#4e3a2e",
        "titleBar.inactiveForeground": "#ADC178",
        "tree.indentGuidesStroke": "#5C3D2E",
        "widget.shadow": "#3a322a40"
    },
    "tokenColors": [
        {
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control",
                "keyword.operator.assignment.js",
                "keyword.control.conditional.js",
                "storage.type.function.js",
                "source.scss keyword.control",
                "keyword.control.at-rule"
            ],
            "settings": {
                "foreground": "#E0956A",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["keyword.control"],
            "settings": {
                "fontStyle": "italic bold"
            }
        },
        {
            "scope": [
                "entity.name.function",
                "meta.class-method.js entity.name.function.js",
                "variable.function.constructor",
                "entity.name.method.js"
            ],
            "settings": {
                "foreground": "#C9A96E",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted.double.html",
                "string.quoted.double.json",
                "markup.fenced_code.block.markdown",
                "markup.inline.raw.string.markdown",
                "string.quoted.single.js",
                "string.other.link.title.markdown"
            ],
            "settings": {
                "foreground": "#b87a50"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "constant.language",
                "constant.character",
                "constant.escape",
                "keyword.other.unit"
            ],
            "settings": {
                "foreground": "#D4A853"
            }
        },
        {
            "scope": [
                "variable",
                "string constant.other.placeholder",
                "variable.other.readwrite.js",
                "variable.other.object.js",
                "variable.other.property.js",
                "variable.other.constant.js",
                "variable.other.object.property.js",
                "variable.import.parameter.js"
            ],
            "settings": {
                "foreground": "#E8C99A",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "entity.name",
                "entity.name.type",
                "entity.name.class",
                "entity.name.module.js",
                "variable.other.class.js",
                "support.class",
                "entity.other.inherited-class",
                "entity.name.type.module.js",
                "support.type.sys-types"
            ],
            "settings": {
                "foreground": "#ADC178",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "source.css support.type.property-name",
                "source.sass support.type.property-name",
                "source.scss support.type.property-name",
                "source.less support.type.property-name",
                "source.postcss support.type.property-name",
                "variable.parameter",
                "variable.parameter.function.language.special"
            ],
            "settings": {
                "foreground": "#ADC178"
            }
        },
        {
            "scope": [
                "variable.parameter.js",
                "variable.parameter.keyframe-list.css"
            ],
            "settings": {
                "foreground": "#E8C99A"
            }
        },
        {
            "scope": [
                "comment.line.scss",
                "comment.line.double-slash.js",
                "comment.block",
                "comment.block.html",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#7a6e62",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "punctuation",
                "punctuation.definition.tag",
                "punctuation.separator.inheritance.php",
                "punctuation.definition.tag.html",
                "punctuation.section.embedded",
                "punctuation.definition.binding-pattern.object.js",
                "punctuation.separator.comma.js"
            ],
            "settings": {
                "foreground": "#a08070"
            }
        },
        {
            "scope": [
                "punctuation.definition.string.begin.html",
                "punctuation.definition.string.end.html",
                "punctuation.definition.string.begin.js",
                "punctuation.definition.string.end.js",
                "string.quoted.single.scss"
            ],
            "settings": {
                "foreground": "#b87a50"
            }
        },
        {
            "scope": [
                "punctuation.definition.tag.begin.html",
                "punctuation.definition.tag.end.html"
            ],
            "settings": {
                "foreground": "#E0956A",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "entity.name.tag",
                "meta.tag.sgml",
                "entity.name.tag.html",
                "entity.name.tag.block.any.html",
                "entity.name.tag.other.html",
                "entity.name.tag.reference.scss"
            ],
            "settings": {
                "foreground": "#E0956A",
                "fontStyle": "italic bold"
            }
        },
        {
            "scope": [
                "entity.name.tag.css",
                "entity.other.attribute-name.id",
                "entity.other.attribute-name.class",
                "entity.other.attribute-name.pseudo-class"
            ],
            "settings": {
                "foreground": "#D4A853"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name",
                "entity.other.attribute-name.html"
            ],
            "settings": {
                "foreground": "#E8C99A"
            }
        },
        {
            "scope": [
                "support.function",
                "support.constant",
                "support.other.variable"
            ],
            "settings": {
                "foreground": "#C9A96E"
            }
        },
        {
            "scope": ["support.type"],
            "settings": {
                "foreground": "#ADC178"
            }
        },
        {
            "scope": [
                "meta.object-literal.key",
                "constant.other.object.key.js",
                "string.unquoted.label.js",
                "support.type.property-name.json"
            ],
            "settings": {
                "foreground": "#E8C99A",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["text.html.derivative"],
            "settings": {
                "foreground": "#E8C99A"
            }
        },
        {
            "scope": [
                "text.html.markdown",
                "punctuation.definition.list_item.markdown"
            ],
            "settings": {
                "foreground": "#E8C99A"
            }
        },
        {
            "scope": [
                "markdown.heading",
                "markup.heading",
                "markup.heading entity.name",
                "markup.heading.markdown punctuation.definition.heading.markdown",
                "entity.name.section.markdown"
            ],
            "settings": {
                "foreground": "#ADC178",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["markup.bold", "markup.bold.markdown"],
            "settings": {
                "foreground": "#E0956A",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["markup.italic.markdown"],
            "settings": {
                "foreground": "#E8C99A",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["markup.inserted", "markup.inserted.git_gutter"],
            "settings": {
                "foreground": "#ADC178"
            }
        },
        {
            "scope": ["markup.deleted", "markup.deleted.git_gutter"],
            "settings": {
                "foreground": "#E0956A"
            }
        },
        {
            "scope": ["markup.changed", "markup.changed.git_gutter"],
            "settings": {
                "foreground": "#D4A853"
            }
        },
        {
            "scope": ["markup.underline"],
            "settings": {
                "foreground": "#C9A96E",
                "fontStyle": "underline"
            }
        },
        {
            "scope": ["markup.quote"],
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "markup.quote punctuation.definition.blockquote.markdown"
            ],
            "settings": {
                "foreground": "#ADC17870"
            }
        },
        {
            "scope": [
                "markup.raw.block",
                "text.html.markdown markup.inline.raw.markdown"
            ],
            "settings": {
                "foreground": "#E8C99A"
            }
        },
        {
            "scope": ["string.regexp", "constant.character.escape"],
            "settings": {
                "foreground": "#E0956A"
            }
        },
        {
            "scope": ["invalid", "invalid.illegal"],
            "settings": {
                "foreground": "#f07050"
            }
        },
        {
            "scope": ["invalid.deprecated"],
            "settings": {
                "foreground": "#E8C99A"
            }
        },
        {
            "scope": ["variable.language.fenced.markdown"],
            "settings": {
                "foreground": "#ADC178"
            }
        },
        {
            "scope": ["meta.separator"],
            "settings": {
                "foreground": "#a08070",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["*url*", "*link*", "*uri*"],
            "settings": {
                "fontStyle": "underline"
            }
        },
        {
            "scope": "token.info-token",
            "settings": { "foreground": "#ADC178" }
        },
        {
            "scope": "token.warn-token",
            "settings": { "foreground": "#D4A853" }
        },
        {
            "scope": "token.error-token",
            "settings": { "foreground": "#f07050" }
        },
        {
            "scope": "token.debug-token",
            "settings": { "foreground": "#C9A96E" }
        }
    ]
}
